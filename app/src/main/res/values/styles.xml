<resources>

    <!-- 全局主題：保留視窗標題列（舊式 Activity 需要），但關閉 ActionBar widget -->
    <style name="AppTheme" parent="Theme.AppCompat">
        <item name="android:textColorPrimary">@color/holo_gray_bright</item>
        <item name="android:textColorSecondary">@color/holo_gray_bright</item>
        <item name="android:alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="android:windowTitleStyle">@style/AppDialogTitleStyle</item>
        <item name="android:windowTitleSize">30dp</item>
        <item name="android:windowTitleBackgroundStyle">@style/AppWindowTitleBackgroundStyle</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowNoTitle">false</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="AppTheme.ActionBar" parent="Theme.AppCompat">
        <item name="android:textColorPrimary">@color/holo_gray_bright</item>
        <item name="android:textColorSecondary">@color/holo_gray_bright</item>
        <item name="android:alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="android:windowTitleStyle">@style/AppDialogTitleStyle</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <!-- 只給 MainCompatActivity（Compose+Fragment 主畫面）使用，不需要標題列 -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="android:textColorPrimary">@color/holo_gray_bright</item>
        <item name="android:textColorSecondary">@color/holo_gray_bright</item>
        <item name="android:alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="alertDialogTheme">@style/AppAlertDialogTheme</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <style name="AppAlertDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:textColorPrimary">@color/holo_gray_bright</item>
        <item name="android:textColorSecondary">@color/holo_gray_bright</item>
        <item name="android:windowBackground">@color/holo_gray_dark</item>
        <item name="android:colorBackground">@color/holo_gray_dark</item>
        <item name="colorAccent">@color/holo_blue_light</item>
        <item name="buttonBarStyle">@style/AppDialogButtonBarStyle</item>
        <item name="buttonBarButtonStyle">@style/AppDialogButtonBarButtonStyle</item>
        <item name="android:windowTitleStyle">@style/AppDialogTitleStyle</item>
    </style>
 
    <style name="AppDialogTheme" parent="Theme.AppCompat.Dialog">
        <item name="android:textColorPrimary">@color/holo_gray_bright</item>
        <item name="android:textColorSecondary">@color/holo_gray_bright</item>
        <item name="android:windowBackground">@color/holo_gray_dark</item>
        <item name="android:colorBackground">@color/holo_gray_dark</item>
        <item name="colorAccent">@color/holo_blue_light</item>
        <item name="buttonBarStyle">@style/AppDialogButtonBarStyle</item>
        <item name="buttonBarButtonStyle">@style/AppDialogButtonBarButtonStyle</item>
        <item name="android:windowTitleStyle">@style/AppDialogTitleStyle</item>
        <item name="android:windowTitleSize">30dp</item>
        <item name="android:windowTitleBackgroundStyle">@style/AppWindowTitleBackgroundStyle</item>
    </style>

    <style name="AppDialogButtonBarStyle" parent="Widget.AppCompat.ButtonBar.AlertDialog">
        <item name="android:background">#262626</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="AppDialogButtonBarButtonStyle" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/holo_blue_light</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="AppDialogTitleStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textColor">@color/holo_blue_light</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingLeft">8dp</item>
        <item name="android:paddingRight">8dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="CupcakeDialog" parent="android:Theme.Dialog">
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="TextAppearance" parent="android:TextAppearance.Small">
        <item name="android:textStyle">normal</item>
        <item name="android:antialias">true</item>
        <item name="android:textColor">#FF000000</item>
    </style>

    <style name="TextAppearance.ZeroAmount">
        <item name="android:textColor">@color/holo_gray_bright</item>
    </style>

    <style name="TextAppearance.PositiveAmount" parent="android:TextAppearance.Small">
        <item name="android:textColor">@color/positive_amount</item>
    </style>

    <style name="TextAppearance.NegativeAmount" parent="android:TextAppearance.Small">
        <item name="android:textColor">@color/negative_amount</item>
    </style>

    <style name="TextAppearance.BalanceAmount" parent="android:TextAppearance.Small">
        <item name="android:textColor">#737373</item>
    </style>

    <style name="TextAppearance.TransactionAmount" parent="android:TextAppearance.Small">
        <item name="android:textSize">15sp</item>
    </style>

    <style name="MoreButton">
        <item name="android:src">@drawable/spinner_ab_default_holo_light_am</item>
    </style>

    <style name="BorderlessButton">
        <item name="android:background">@android:drawable/list_selector_background</item>
        <item name="android:paddingLeft">4dip</item>
        <item name="android:paddingRight">4dip</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ListButton" parent="BorderlessButton">
        <item name="android:minHeight">40dip</item>
        <item name="android:minWidth">40dip</item>
        <item name="android:focusable">false</item>
        <item name="android:focusableInTouchMode">false</item>
        <item name="android:tint">@color/holo_gray_bright</item>
    </style>

    <style name="MinusButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_minus</item>
    </style>

    <style name="PlusButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_add</item>
    </style>

    <style name="SplitButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_share</item>
    </style>

    <style name="TransferButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_transfer</item>
    </style>

    <style name="EditButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_edit</item>
    </style>

    <style name="FilterButton" parent="ListButton">
        <item name="android:src">@drawable/actionbar_filter</item>
    </style>

    <style name="FilterCancelButton" parent="ListButton">
        <item name="android:src">@drawable/actionbar_filter_cancel</item>
    </style>

    <style name="ShowListButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_list</item>
    </style>

    <style name="DeleteButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_trash</item>
    </style>

    <style name="UpButton">
        <item name="android:src">@drawable/ic_btn_round_up</item>
    </style>

    <style name="DownButton">
        <item name="android:src">@drawable/ic_btn_round_down</item>
    </style>

    <style name="TopButton">
        <item name="android:src">@drawable/ic_btn_round_top</item>
    </style>

    <style name="BottomButton">
        <item name="android:src">@drawable/ic_btn_round_bottom</item>
    </style>

    <style name="UpDownButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_drag</item>
    </style>

    <style name="CalcButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_calculator</item>
    </style>

    <style name="DownloadButton" parent="ListButton">
        <item name="android:src">@drawable/ic_action_download</item>
    </style>

    <style name="TallTitleBarTheme" parent="android:Theme.NoTitleBar">
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="ButtonBar">
        <item name="android:paddingTop">5dip</item>
        <item name="android:paddingLeft">4dip</item>
        <item name="android:paddingRight">4dip</item>
        <item name="android:paddingBottom">1dip</item>
        <item name="android:background">@color/holo_gray_dark</item>
    </style>

    <style name="ProgressBarBudget" parent="@android:style/Widget.ProgressBar.Horizontal">
        <item name="android:progressDrawable">@drawable/progress_horizontal_budget</item>
        <item name="android:minHeight">12dip</item>
        <item name="android:maxHeight">12dip</item>
    </style>

    <style name="BottomBar">
        <item name="android:layout_width">fill_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@color/holo_gray_dark</item>
        <item name="android:minHeight">@dimen/action_button_size</item>
    </style>

    <style name="BottomBarButton">
        <item name="android:background"></item>
        <item name="android:layout_width">@dimen/action_button_size</item>
        <item name="android:layout_height">@dimen/action_button_size</item>
    </style>

    <style name="CalculatorButton">
        <item name="android:textColor">@android:color/secondary_text_dark</item>
        <item name="android:background">@android:drawable/list_selector_background</item>
        <item name="android:layout_width">@dimen/calculator_button_width</item>
        <item name="android:layout_height">@dimen/calculator_button_height</item>
        <item name="android:textSize">26sp</item>
    </style>

    <style name="AccountTypeImage">
        <item name="android:tint">@color/holo_gray_light</item>
    </style>

    <style name="ContactListSeparatorTextViewStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dip</item>
        <!-- See comments for @dimen/list_section_divider_min_height -->
        <item name="android:minHeight">@dimen/list_section_divider_min_height</item>
        <item name="android:background">@drawable/list_section_divider_holo_custom</item>
        <item name="android:textAppearance">?android:attr/textAppearanceSmall</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingLeft">8dip</item>
        <item name="android:ellipsize">end</item>
        <item name="android:fadingEdge">horizontal</item>
        <item name="android:singleLine">true</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="LockButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:minHeight">@dimen/pin_button_height</item>
        <item name="android:minWidth">@dimen/pin_button_width</item>
        <item name="android:textSize">30sp</item>
    </style>

    <style name="AppWindowTitleBackgroundStyle">
        <item name="android:background">@color/holo_gray_dark</item>
    </style>

</resources>
