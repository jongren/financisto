<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Google Account Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sheets_section_account"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tv_account_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sheets_not_linked"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_link_account"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sheets_link_account"
                    android:backgroundTint="#3F51B5"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/btn_unlink_account"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sheets_unlink_account"
                    android:backgroundTint="#424242"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Payee Filter Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sheets_section_payee_filter"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sheets_payee_filter_hint"
                android:textColor="#9E9E9E"
                android:textSize="13sp"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:id="@+id/ll_payee_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- Sync Year Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sheets_section_year"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <Spinner
                android:id="@+id/spinner_sync_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#3F51B5"
                android:popupBackground="#1E1E1E" />

        </LinearLayout>

        <!-- Monthly Budget Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sheets_section_budget"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/et_monthly_budget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#424242"
                android:backgroundTint="#3F51B5" />

        </LinearLayout>

        <!-- Auto Sync Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sheets_section_auto_sync"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="24dp">

            <Spinner
                android:id="@+id/spinner_sync_frequency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#3F51B5"
                android:popupBackground="#1E1E1E" />

        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sheets_save_settings"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <!-- Manual Sync Button -->
        <Button
            android:id="@+id/btn_sync_now"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sheets_sync_now"
            android:backgroundTint="@color/btn_sync_now_tint"
            android:textColor="@color/btn_sync_now_text"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
